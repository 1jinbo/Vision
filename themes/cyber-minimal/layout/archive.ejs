<%- partial('_partial/header') %>

<main class="cyber-main">
  <div class="cyber-content">
    <div class="archive-header">
      <h1 class="archive-title">
        <% if (page.archive) { %>
          归档
        <% } else if (page.tag) { %>
          标签: <span class="tag-name"><%= page.tag %></span>
        <% } else if (page.category) { %>
          分类: <span class="category-name"><%= page.category %></span>
        <% } %>
      </h1>
      
      <% if (page.total) { %>
        <div class="archive-meta">
          共 <%= page.total %> 篇文章
        </div>
      <% } %>
    </div>
    
    <% if (page.posts && page.posts.length > 0) { %>
      <div class="archive-list">
        <% page.posts.each(function(post) { %>
          <article class="archive-post">
            <h2 class="archive-post-title">
              <a href="<%- url_for(post.path) %>"><%= post.title %></a>
            </h2>
            
            <div class="archive-post-meta">
              <time class="archive-post-date" datetime="<%= post.date.toISOString() %>">
                <i class="far fa-calendar"></i>
                <%= date(post.date, 'YYYY-MM-DD') %>
              </time>
              
              <% if (post.categories && post.categories.length > 0) { %>
                <span class="archive-post-category">
                  <i class="far fa-folder"></i>
                  <% post.categories.each(function(category, index) { %>
                    <a href="<%- url_for(category.path) %>"><%= category.name %></a>
                    <% if (index < post.categories.length - 1) { %>, <% } %>
                  <% }) %>
                </span>
              <% } %>
              
              <% if (post.tags && post.tags.length > 0) { %>
                <span class="archive-post-tags">
                  <i class="fas fa-tags"></i>
                  <% post.tags.each(function(tag, index) { %>
                    <a href="<%- url_for(tag.path) %>"><%= tag.name %></a>
                    <% if (index < post.tags.length - 1) { %>, <% } %>
                  <% }) %>
                </span>
              <% } %>
            </div>
            
            <% if (post.excerpt) { %>
              <div class="archive-post-excerpt">
                <%- post.excerpt %>
              </div>
            <% } %>
          </article>
        <% }) %>
      </div>
      
      <!-- 分页 -->
      <%- partial('_partial/pagination') %>
    <% } else { %>
      <div class="no-archive">
        <h3>暂无内容</h3>
        <p>这里还没有发布任何文章。</p>
      </div>
    <% } %>
  </div>
  
  <!-- 侧边栏 -->
  <% if (theme.sidebar && theme.sidebar !== 'none') { %>
    <aside class="cyber-sidebar">
      <%- partial('_partial/sidebar') %>
    </aside>
  <% } %>
</main>

<%- partial('_partial/footer') %>